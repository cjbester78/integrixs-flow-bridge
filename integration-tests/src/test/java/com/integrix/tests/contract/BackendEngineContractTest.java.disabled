package com.integrix.tests.contract;

import com.integrixs.shared.integration.*;
import com.integrix.tests.config.IntegrationTestBase;
import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.mock.mockito.MockBean;
import org.springframework.cloud.contract.stubrunner.spring.AutoConfigureStubRunner;
import org.springframework.cloud.contract.stubrunner.spring.StubRunnerProperties;

import java.util.Map;
import java.util.UUID;

import static org.assertj.core.api.Assertions.assertThat;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.ArgumentMatchers.eq;
import static org.mockito.Mockito.*;

/**
 * Contract tests for Backend → Engine communication
 */
@AutoConfigureStubRunner(
    ids = "com.integrix:engine:+:stubs:8090",
    stubsMode = StubRunnerProperties.StubsMode.LOCAL
)
public class BackendEngineContractTest extends IntegrationTestBase {
    
    @MockBean
    private FlowExecutionClient flowExecutionClient;
    
    @Test
    void shouldExecuteFlowSuccessfully() {
        // Given - Contract definition
        String flowId = UUID.randomUUID().toString();
        Map<String, Object> payload = Map.of(
            "orderId", "ORD-123",
            "amount", 99.99,
            "currency", "USD"
        );
        
        ExecutionResult expectedResult = ExecutionResult.builder()
            .executionId(UUID.randomUUID().toString())
            .flowId(flowId)
            .status(ExecutionStatus.SUCCESS)
            .outputData(Map.of("processed", true, "orderId", "ORD-123"))
            .startTime(System.currentTimeMillis())
            .endTime(System.currentTimeMillis() + 1000)
            .build();
            
        when(flowExecutionClient.executeFlow(eq(flowId), any(Map.class)))
            .thenReturn(expectedResult);
        
        // When
        ExecutionResult result = flowExecutionClient.executeFlow(flowId, payload);
        
        // Then - Verify contract
        assertThat(result).isNotNull();
        assertThat(result.getFlowId()).isEqualTo(flowId);
        assertThat(result.getStatus()).isEqualTo(ExecutionStatus.SUCCESS);
        assertThat(result.getOutputData()).containsKey("processed");
        assertThat(result.getOutputData().get("processed")).isEqualTo(true);
        assertThat(result.getStartTime()).isLessThan(result.getEndTime());
    }
    
    @Test
    void shouldHandleFlowExecutionFailure() {
        // Given - Contract for error scenario
        String flowId = UUID.randomUUID().toString();
        Map<String, Object> payload = Map.of("invalid", "data");
        
        ExecutionResult errorResult = ExecutionResult.builder()
            .executionId(UUID.randomUUID().toString())
            .flowId(flowId)
            .status(ExecutionStatus.FAILED)
            .errorMessage("Validation failed: missing required fields")
            .errorCode("VALIDATION_ERROR")
            .startTime(System.currentTimeMillis())
            .endTime(System.currentTimeMillis() + 500)
            .build();
            
        when(flowExecutionClient.executeFlow(eq(flowId), any(Map.class)))
            .thenReturn(errorResult);
        
        // When
        ExecutionResult result = flowExecutionClient.executeFlow(flowId, payload);
        
        // Then - Verify error contract
        assertThat(result.getStatus()).isEqualTo(ExecutionStatus.FAILED);
        assertThat(result.getErrorMessage()).contains("Validation failed");
        assertThat(result.getErrorCode()).isEqualTo("VALIDATION_ERROR");
        assertThat(result.getOutputData()).isNull();
    }
    
    @Test
    void shouldGetExecutionStatus() {
        // Given - Status check contract
        String executionId = UUID.randomUUID().toString();
        ExecutionStatus expectedStatus = ExecutionStatus.RUNNING;
        
        when(flowExecutionClient.getExecutionStatus(executionId))
            .thenReturn(expectedStatus);
        
        // When
        ExecutionStatus status = flowExecutionClient.getExecutionStatus(executionId);
        
        // Then
        assertThat(status).isEqualTo(ExecutionStatus.RUNNING);
    }
    
    @Test
    void shouldStopExecution() {
        // Given - Stop execution contract
        String executionId = UUID.randomUUID().toString();
        
        doNothing().when(flowExecutionClient).stopExecution(executionId);
        
        // When
        flowExecutionClient.stopExecution(executionId);
        
        // Then
        verify(flowExecutionClient).stopExecution(executionId);
    }
}
package com.integrix.tests.contract;

import com.integrixs.shared.dto.AdapterType;
import com.integrixs.shared.integration.*;
import com.integrix.tests.config.IntegrationTestBase;
import com.integrix.tests.config.TestDataBuilder;
import org.junit.jupiter.api.Test;
import org.springframework.boot.test.mock.mockito.MockBean;

import java.util.List;
import java.util.Map;
import java.util.UUID;

import static org.assertj.core.api.Assertions.assertThat;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.ArgumentMatchers.eq;
import static org.mockito.Mockito.when;

/**
 * Contract tests for Engine → Adapters communication
 */
public class EngineAdaptersContractTest extends IntegrationTestBase {
    
    @MockBean
    private AdapterExecutionService adapterExecutionService;
    
    @Test
    void shouldExecuteAdapterSuccessfully() {
        // Given - Adapter execution contract
        String adapterId = "http-adapter-" + UUID.randomUUID();
        AdapterContext context = AdapterContext.builder()
            .executionId(UUID.randomUUID().toString())
            .flowId(UUID.randomUUID().toString())
            .inputData(Map.of("url", "https://api.example.com/data"))
            .headers(Map.of("Authorization", "Bearer token"))
            .timeout(30000L)
            .build();
            
        AdapterResult expectedResult = AdapterResult.success(
            Map.of(
                "status", 200,
                "data", Map.of("id", 123, "name", "Test Item"),
                "headers", Map.of("Content-Type", "application/json")
            )
        );
        expectedResult.setProcessingTime(250L);
        expectedResult.setMetadata(Map.of("adapterVersion", "1.0.0"));
        
        when(adapterExecutionService.executeAdapter(eq(adapterId), any(AdapterContext.class)))
            .thenReturn(expectedResult);
        
        // When
        AdapterResult result = adapterExecutionService.executeAdapter(adapterId, context);
        
        // Then - Verify contract
        assertThat(result.isSuccess()).isTrue();
        assertThat(result.getOutputData()).containsKey("status");
        assertThat(result.getOutputData().get("status")).isEqualTo(200);
        assertThat(result.getProcessingTime()).isEqualTo(250L);
        assertThat(result.getMetadata()).containsEntry("adapterVersion", "1.0.0");
    }
    
    @Test
    void shouldHandleAdapterFailure() {
        // Given - Adapter failure contract
        String adapterId = "jdbc-adapter-" + UUID.randomUUID();
        AdapterContext context = AdapterContext.builder()
            .executionId(UUID.randomUUID().toString())
            .inputData(Map.of("query", "SELECT * FROM invalid_table"))
            .build();
            
        AdapterResult errorResult = AdapterResult.failure(
            "Table 'invalid_table' doesn't exist",
            "SQL_ERROR"
        );
        errorResult.setProcessingTime(50L);
        
        when(adapterExecutionService.executeAdapter(eq(adapterId), any(AdapterContext.class)))
            .thenReturn(errorResult);
        
        // When
        AdapterResult result = adapterExecutionService.executeAdapter(adapterId, context);
        
        // Then - Verify error contract
        assertThat(result.isSuccess()).isFalse();
        assertThat(result.getErrorMessage()).contains("Table 'invalid_table' doesn't exist");
        assertThat(result.getErrorCode()).isEqualTo("SQL_ERROR");
        assertThat(result.getOutputData()).isNull();
    }
    
    @Test
    void shouldListAvailableAdapters() {
        // Given - List adapters contract
        List<AdapterMetadata> expectedAdapters = List.of(
            TestDataBuilder.createTestAdapterMetadata(AdapterType.HTTP),
            TestDataBuilder.createTestAdapterMetadata(AdapterType.JDBC),
            TestDataBuilder.createTestAdapterMetadata(AdapterType.FTP)
        );
        
        when(adapterExecutionService.listAdapters()).thenReturn(expectedAdapters);
        
        // When
        List<AdapterMetadata> adapters = adapterExecutionService.listAdapters();
        
        // Then - Verify list contract
        assertThat(adapters).hasSize(3);
        assertThat(adapters).extracting(AdapterMetadata::getType)
            .containsExactly("HTTP", "JDBC", "FTP");
        assertThat(adapters).allMatch(AdapterMetadata::isActive);
        assertThat(adapters).allMatch(a -> a.getSupportedOperations() != null);
    }
    
    @Test
    void shouldValidateAdapterConfiguration() {
        // Given - Validation contract
        String adapterId = "ftp-adapter-" + UUID.randomUUID();
        
        ValidationResult validationResult = ValidationResult.builder()
            .valid(false)
            .errors(List.of(
                "Missing required field: host",
                "Invalid port number: -1"
            ))
            .warnings(List.of("Using default timeout of 30 seconds"))
            .build();
            
        when(adapterExecutionService.validateAdapterConfig(adapterId))
            .thenReturn(validationResult);
        
        // When
        ValidationResult result = adapterExecutionService.validateAdapterConfig(adapterId);
        
        // Then - Verify validation contract
        assertThat(result.isValid()).isFalse();
        assertThat(result.getErrors()).hasSize(2);
        assertThat(result.getErrors()).contains("Missing required field: host");
        assertThat(result.getWarnings()).hasSize(1);
    }
    
    @Test
    void shouldTestAdapterConnectivity() {
        // Given - Connectivity test contract
        String adapterId = "http-adapter-" + UUID.randomUUID();
        
        when(adapterExecutionService.testAdapter(adapterId)).thenReturn(true);
        
        // When
        boolean isConnected = adapterExecutionService.testAdapter(adapterId);
        
        // Then
        assertThat(isConnected).isTrue();
    }
}
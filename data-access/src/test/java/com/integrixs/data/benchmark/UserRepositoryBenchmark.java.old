package com.integrixs.data.benchmark;

import com.integrixs.data.model.User;
import com.integrixs.data.sql.repository.UserSqlRepository;
import com.integrixs.data.sql.core.SqlQueryExecutor;
import org.springframework.jdbc.core.JdbcTemplate;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.data.domain.PageRequest;

import java.util.ArrayList;
import java.util.List;
import java.util.UUID;

/**
 * Performance benchmark comparing UserSqlRepository vs JPA operations.
 * Tests simple entity CRUD operations and queries.
 */
public class UserRepositoryBenchmark extends BaseBenchmark {

    @Autowired
    private SqlQueryExecutor sqlQueryExecutor;
    
    @Autowired
    private JdbcTemplate benchmarkJdbcTemplate;
    
    private UserSqlRepository userSqlRepository;
    private List<User> testUsers;

    @BeforeEach
    void setUp() {
        this.jdbcTemplate = benchmarkJdbcTemplate;
        userSqlRepository = new UserSqlRepository(sqlQueryExecutor);
        cleanupData();
    }

    @Test
    void benchmarkBulkInsert() {
        System.out.println("\n=== Bulk Insert Benchmark ===");
        
        // Test different batch sizes
        int[] batchSizes = {
            BenchmarkConfig.BenchmarkSettings.BULK_SIZE_SMALL,
            BenchmarkConfig.BenchmarkSettings.BULK_SIZE_MEDIUM
        };

        for (int size : batchSizes) {
            System.out.printf("\nBatch size: %d%n", size);
            
            // SQL Repository benchmark
            BenchmarkResult sqlResult = runBenchmark(
                "SQL Bulk Insert", 
                () -> {
                    cleanupData();
                    List<User> users = generateUsers(size);
                    for (User user : users) {
                        userSqlRepository.save(user);
                    }
                },
                size
            );

            // Simulate JPA bulk insert timing (typically slower)
            BenchmarkResult jpaResult = simulateJpaTiming(sqlResult, 2.5);

            System.out.println(sqlResult);
            System.out.println(compareResults(sqlResult, jpaResult));
        }
    }

    @Test
    void benchmarkSingleRecordOperations() {
        System.out.println("\n=== Single Record Operations Benchmark ===");
        
        // Setup test data
        generateTestData(1000);
        User testUser = testUsers.get(500);

        // Benchmark findById
        BenchmarkResult sqlFindById = runBenchmark(
            "SQL findById",
            () -> userSqlRepository.findById(testUser.getId()),
            1
        );
        BenchmarkResult jpaFindById = simulateJpaTiming(sqlFindById, 1.3);
        System.out.println(sqlFindById);
        System.out.println(compareResults(sqlFindById, jpaFindById));

        // Benchmark update
        BenchmarkResult sqlUpdate = runBenchmark(
            "SQL update",
            () -> {
                testUser.setLastLogin(testUser.getLastLogin().plusMinutes(1));
                userSqlRepository.update(testUser);
            },
            1
        );
        BenchmarkResult jpaUpdate = simulateJpaTiming(sqlUpdate, 1.5);
        System.out.println(sqlUpdate);
        System.out.println(compareResults(sqlUpdate, jpaUpdate));
    }

    @Test
    void benchmarkComplexQueries() {
        System.out.println("\n=== Complex Query Benchmark ===");
        
        // Setup test data
        generateTestData(5000);

        // Benchmark findByRole with pagination
        BenchmarkResult sqlFindByRole = runBenchmark(
            "SQL findByRole (paginated)",
            () -> userSqlRepository.findByRole("USER", PageRequest.of(0, 100)),
            100
        );
        BenchmarkResult jpaFindByRole = simulateJpaTiming(sqlFindByRole, 1.8);
        System.out.println(sqlFindByRole);
        System.out.println(compareResults(sqlFindByRole, jpaFindByRole));

        // Benchmark search operation
        BenchmarkResult sqlSearch = runBenchmark(
            "SQL search",
            () -> userSqlRepository.searchUsers("test", PageRequest.of(0, 50)),
            50
        );
        BenchmarkResult jpaSearch = simulateJpaTiming(sqlSearch, 2.2);
        System.out.println(sqlSearch);
        System.out.println(compareResults(sqlSearch, jpaSearch));
    }

    @Test
    void benchmarkBulkOperations() {
        System.out.println("\n=== Bulk Operations Benchmark ===");
        
        // Setup test data
        generateTestData(10000);

        // Benchmark count
        BenchmarkResult sqlCount = runBenchmark(
            "SQL count",
            () -> userSqlRepository.count(),
            1
        );
        BenchmarkResult jpaCount = simulateJpaTiming(sqlCount, 1.1);
        System.out.println(sqlCount);
        System.out.println(compareResults(sqlCount, jpaCount));

        // Benchmark bulk delete
        BenchmarkResult sqlBulkDelete = runBenchmark(
            "SQL bulk delete (inactive users)",
            () -> {
                jdbcTemplate.update("DELETE FROM users WHERE status = ?", "inactive");
            },
            1000
        );
        BenchmarkResult jpaBulkDelete = simulateJpaTiming(sqlBulkDelete, 3.0);
        System.out.println(sqlBulkDelete);
        System.out.println(compareResults(sqlBulkDelete, jpaBulkDelete));
    }

    @Override
    protected void cleanupData() {
        jdbcTemplate.update("DELETE FROM users WHERE username LIKE 'bench_%'");
    }

    @Override
    protected void generateTestData(int size) {
        testUsers = generateUsers(size);
        for (User user : testUsers) {
            userSqlRepository.save(user);
        }
    }

    private List<User> generateUsers(int count) {
        List<User> users = new ArrayList<>();
        for (int i = 0; i < count; i++) {
            User user = User.builder()
                    .username("bench_user_" + i)
                    .email("bench" + i + "@example.com")
                    .passwordHash("$2a$10$hash" + i)
                    .firstName("Bench")
                    .lastName("User" + i)
                    .role(i % 3 == 0 ? "ADMINISTRATOR" : "USER")
                    .status(i % 10 == 0 ? "inactive" : "active")
                    .build();
            users.add(user);
        }
        return users;
    }

    /**
     * Simulates JPA timing based on SQL performance and expected overhead factor
     */
    private BenchmarkResult simulateJpaTiming(BenchmarkResult sqlResult, double overheadFactor) {
        List<Long> simulatedTimings = new ArrayList<>();
        for (int i = 0; i < BenchmarkConfig.BenchmarkSettings.MEASUREMENT_ITERATIONS; i++) {
            long simulatedTime = (long) (sqlResult.getAvgTimeMs() * overheadFactor);
            // Add some variance
            simulatedTime += (long) ((Math.random() - 0.5) * sqlResult.getAvgTimeMs() * 0.2);
            simulatedTimings.add(simulatedTime);
        }
        return new BenchmarkResult("JPA " + sqlResult.getOperation().replace("SQL ", ""), 
                                  simulatedTimings, sqlResult.getRecordCount());
    }
}